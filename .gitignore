# ── Database ─────────────────────────────────────────────────────────────
# Never track the live SQLite database (and its WAL/SHM sidecar files from
# PRAGMA journal_mode=WAL) so a force-push or history rewrite can never
# touch, overwrite, or roll back the real data sitting on the server.
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
backend/motoshop.db
backend/instance/

# Backups produced by the app's own backup/export feature
*backup*.db
backend/backups/

# ── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
*.egg-info/

# ── Environment / secrets ────────────────────────────────────────────────
.env
.env.local
*.pem
*.key

# ── Node / frontend build ────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/build/
.vite/

# ── Logs ─────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── OS / editor cruft ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
